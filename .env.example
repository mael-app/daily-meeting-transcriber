# Rename this file to .env and fill in your secrets

# API key for your OpenAI-compatible platform
OPENAI_API_KEY=""

# Optional: override endpoints and models (defaults to OpenAI)
# Use this to point to any OpenAI-compatible API (Azure OpenAI, Together AI, local inference servers, etc.)
# OPENAI_WHISPER_ENDPOINT="https://api.openai.com/v1/audio/transcriptions"
# OPENAI_CHAT_ENDPOINT="https://api.openai.com/v1/chat/completions"
# WHISPER_MODEL="whisper-1"
# CHAT_MODEL="gpt-4o-mini"

# Notion API Key
NOTION_TOKEN=""

# Notion Title (optional, default: "Daily")
NOTION_TITLE="Daily"

# Notion Category (optional, default: "Standup")
NOTION_CATEGORY="Standup"

# Notion DB Schema as a JSON string
# Example: NOTION_DB_SCHEMA='{"database_id": "...", "properties": {...}}'
NOTION_DB_SCHEMA='{}'

# Custom prompts (required, JSON string)
# {transcript} placeholder is required in user_prompt
PROMPT_CONFIG='{"system_prompt": "You are an assistant that generates a structured Markdown summary of a developer daily standup.", "user_prompt": "Analyze the transcript and extract: completed work, today'\''s plan, code reviews, technical points, and action items.\n\nFollow this format:\n\n### Work from yesterday\n- Concise list of yesterday'\''s achievements.\n\n### Today'\''s organization\n- Meetings, priorities, or tasks planned for today.\n\n### Code reviews\n- PRs to review or pending.\n\n### Technical points\n- Problems, proposals, or technical reflections raised.\n\n### Action Items\n- [ ] Next identified actions.\n\nRules: professional tone, no digressions, max 10 lines per section, skip empty sections.\n\nTranscript:\n---\n{transcript}\n---", "language": "en"}'
